{
  "name": "depguard",
  "version": "0.2.0",
  "description": "MCP stdio server for npm dependency security/deprecation checks via OSV + npm registry",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "depguard-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "proof:generate": "node scripts/generate-proof.mjs",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "security",
    "osv",
    "dependencies",
    "vulnerability-scanner"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
